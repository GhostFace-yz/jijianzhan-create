{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "name": "极简栈 AI 聊天网页端 — 色彩系统",
  "version": "1.0",
  "modes": {
    "dark": {
      "background": "#0F0F10",
      "foreground": "#F2F2F5",
      "card": "#18181B",
      "card-foreground": "#F2F2F5",
      "popover": "#1C1C1F",
      "popover-foreground": "#F2F2F5",
      "primary": "#6366F1",
      "primary-foreground": "#FFFFFF",
      "secondary": "#27272A",
      "secondary-foreground": "#E4E4E7",
      "muted": "#27272A",
      "muted-foreground": "#A1A1AA",
      "accent": "#3F3F46",
      "accent-foreground": "#F2F2F5",
      "destructive": "#EF4444",
      "destructive-foreground": "#FFFFFF",
      "border": "#27272A",
      "input": "#27272A",
      "ring": "#6366F1",
      "success": "#22C55E",
      "warning": "#F59E0B",
      "info": "#3B82F6",
      "ai-message-bg": "#1C1C1F",
      "user-message-bg": "#312E81",
      "sidebar-bg": "#0F0F10",
      "sidebar-active": "#27272A",
      "code-bg": "#18181B",
      "code-border": "#27272A",
      "streaming-cursor": "#6366F1"
    },
    "light": {
      "background": "#FAFAFA",
      "foreground": "#18181B",
      "card": "#FFFFFF",
      "card-foreground": "#18181B",
      "popover": "#FFFFFF",
      "popover-foreground": "#18181B",
      "primary": "#6366F1",
      "primary-foreground": "#FFFFFF",
      "secondary": "#F4F4F5",
      "secondary-foreground": "#27272A",
      "muted": "#F4F4F5",
      "muted-foreground": "#71717A",
      "accent": "#F4F4F5",
      "accent-foreground": "#18181B",
      "destructive": "#EF4444",
      "destructive-foreground": "#FFFFFF",
      "border": "#E4E4E7",
      "input": "#E4E4E7",
      "ring": "#6366F1",
      "success": "#22C55E",
      "warning": "#F59E0B",
      "info": "#3B82F6",
      "ai-message-bg": "#FFFFFF",
      "user-message-bg": "#E0E7FF",
      "sidebar-bg": "#FAFAFA",
      "sidebar-active": "#F4F4F5",
      "code-bg": "#F4F4F5",
      "code-border": "#E4E4E7",
      "streaming-cursor": "#6366F1"
    }
  },
  "gradients": {
    "hero": "linear-gradient(135deg, #312E81 0%, #1E1B4B 50%, #0F0F10 100%)",
    "glow": "radial-gradient(circle at 50% 0%, rgba(99,102,241,0.15) 0%, transparent 60%)",
    "glass": "rgba(24,24,27,0.85)"
  },
  "shadows": {
    "sm": "0 1px 2px rgba(0,0,0,0.3)",
    "md": "0 4px 12px rgba(0,0,0,0.4)",
    "lg": "0 8px 24px rgba(0,0,0,0.5)",
    "glow": "0 0 20px rgba(99,102,241,0.15)",
    "inset": "inset 0 1px 2px rgba(0,0,0,0.2)"
  }
}
