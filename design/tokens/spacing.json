    "4": { "value": "16px", "px": 16 },
    "5": { "value": "20px", "px": 20 },
    "6": { "value": "24px", "px": 24 },
    "8": { "value": "32px", "px": 32 },
    "10": { "value": "40px", "px": 40 },
