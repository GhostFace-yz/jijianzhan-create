{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "name": "极简栈 AI 聊天网页端 — 字体排版系统",
  "version": "1.0",
  "families": {
    "sans": {
      "primary": "Inter",
      "fallback": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
      "chinese": "'Noto Sans SC', 'PingFang SC', 'Microsoft YaHei', sans-serif"
    },
    "mono": {
      "primary": "JetBrains Mono",
      "fallback": "'Fira Code', 'SF Mono', 'Cascadia Code', monospace"
    }
  },
  "scale": {
    "xs": { "desktop": "12px", "mobile": "11px", "weight": 400, "lineHeight": 1.5, "letterSpacing": "0" },
    "sm": { "desktop": "14px", "mobile": "13px", "weight": 400, "lineHeight": 1.5, "letterSpacing": "0" },
    "base": { "desktop": "16px", "mobile": "15px", "weight": 400, "lineHeight": 1.6, "letterSpacing": "0" },
    "lg": { "desktop": "18px", "mobile": "16px", "weight": 500, "lineHeight": 1.5, "letterSpacing": "-0.01em" },
    "xl": { "desktop": "20px", "mobile": "18px", "weight": 600, "lineHeight": 1.4, "letterSpacing": "-0.02em" },
    "2xl": { "desktop": "24px", "mobile": "20px", "weight": 600, "lineHeight": 1.3, "letterSpacing": "-0.02em" },
    "3xl": { "desktop": "30px", "mobile": "24px", "weight": 700, "lineHeight": 1.2, "letterSpacing": "-0.03em" },
    "4xl": { "desktop": "36px", "mobile": "28px", "weight": 700, "lineHeight": 1.1, "letterSpacing": "-0.03em" }
  },
  "rules": {
    "trackingTightThreshold": "20px",
    "messageFontSize": "base",
    "codeFontSize": "0.875em",
    "minReadableSize": "12px"
  }
}
