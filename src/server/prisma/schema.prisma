generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model characters {
  id                String   @id @default(uuid())
  project_id        String
  name              String
  role_type         String
  episode_range     String?
  appearance        String?
  costume           String?
  expression        String?
  signature_action  String?
  voice_description String?
  status            String   @default("draft")
  ref_images        Json
  ip_adapter_id     String?
  lora_path         String?
  created_at        DateTime @default(now())
  updated_at        DateTime @default(now())

  @@index([project_id])
}

model downstream_review_flags {
  id                 String   @id @default(uuid())
  project_id         String
  source_entity_type String
  source_entity_id   String
  source_version_id  String
  new_version_id     String
  status             String   @default("pending_review")
  created_at         DateTime @default(now())
  updated_at         DateTime @default(now())

  @@index([status])
  @@index([project_id, source_entity_type, source_entity_id])
}

model locations {
  id            String   @id @default(uuid())
  project_id    String
  name          String
  description   String?
  frequency     String?
  space_type    String?
  style         String?
  color_tone    String?
  lighting_type String?
  key_props     Json
  status        String   @default("draft")
  base_seed     Int?
  base_image_url String?
  variants      Json    @default("[]")
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now())

  @@index([project_id])
}

model projects {
  id             String   @id @default(uuid())
  user_id        String   @default("system")
  team_id        String?
  status         String   @default("draft")
  meta           Json
  outline        Json?
  outline_locked Boolean  @default(false)
  storyboard_nodes Json?
  music            Json?
  render_output    Json?
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now())

  @@index([status])
  @@index([user_id, updated_at(sort: Desc)])
}

model version_counters {
  project_id  String
  entity_type String
  entity_id   String
  counter     Int      @default(0)
  updated_at  DateTime @default(now())

  @@id([project_id, entity_type, entity_id])
}

model version_snapshots {
  id                    String   @id @default(uuid())
  project_id            String
  entity_type           String
  entity_id             String
  version_number        Int
  version_id            String
  source                String
  content               Json
  parent_version_number Int?
  diff                  Json
  edited_by             String?
  ai_model              Json?
  prompt_override       String?
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now())

  @@unique([project_id, entity_type, entity_id, version_number])
  @@index([project_id, entity_type, entity_id, created_at(sort: Desc)])
  @@index([project_id, entity_type, entity_id, version_number(sort: Desc)])
}
